<atlassian-plugin key="com.lmd.workbuddy.jira-workbuddy-plugin" name="WorkBuddy AI for Jira" plugins-version="2">
    <plugin-info>
        <description>AI-powered assistant using DeepSeek. Integrates Jira issues with SVN commits, Notion docs, and Google Drive.</description>
        <version>1.0.0</version>
        <vendor name="LMD"/>
        <param name="configure.url">/plugins/servlet/wb-admin</param>
    </plugin-info>

    <component-import key="userManager" interface="com.atlassian.sal.api.user.UserManager"/>
    <component-import key="loginUriProvider" interface="com.atlassian.sal.api.auth.LoginUriProvider"/>
    <component-import key="templateRenderer" interface="com.atlassian.templaterenderer.TemplateRenderer"/>
    <component-import key="pluginSettingsFactory" interface="com.atlassian.sal.api.pluginsettings.PluginSettingsFactory"/>
    <component-import key="authContext" interface="com.atlassian.jira.security.JiraAuthenticationContext"/>

    <servlet key="wb-admin" class="com.lmd.workbuddy.AdminServlet">
        <url-pattern>/wb-admin</url-pattern>
    </servlet>

    <servlet key="wb-chat" class="com.lmd.workbuddy.ChatEndpoint">
        <url-pattern>/wb/chat</url-pattern>
    </servlet>

    <servlet key="wb-chat-ping" class="com.lmd.workbuddy.ChatEndpoint">
        <url-pattern>/wb/chat/ping</url-pattern>
    </servlet>

    <servlet key="wb-chat-dialog" class="com.lmd.workbuddy.ChatDialogServlet">
        <url-pattern>/wb/chat-dialog</url-pattern>
    </servlet>

    <web-item key="workbuddy-admin-menu" name="WorkBuddy AI 配置" section="system.admin/globalsettings" weight="150">
        <label key="wb.admin.menu.title">WorkBuddy AI 设置</label>
        <link linkId="workbuddy-admin-link">/plugins/servlet/wb-admin</link>
    </web-item>

    <web-resource key="wb-resources">
        <dependency>com.atlassian.auiplugin:ajs</dependency>
        <resource type="download" name="chat.css" location="css/chat.css"/>
        <resource type="download" name="chat.js" location="js/chat.js"/>
        <context>atl.general</context>
    </web-resource>
</atlassian-plugin>
