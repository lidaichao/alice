{
  "name": "alice-jira-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "爱丽丝 Jira AI 桌面端 — Electron + React + PyInstaller",
  "main": "main.js",
  "scripts": {
    "dev": "set NODE_ENV=development && electron main.js",
    "start": "electron main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.4",
    "@electron/universal": "^3.0.4",
    "electron": "^28.3.3",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "build": {
    "appId": "com.alice.desktop.jira",
    "productName": "Alice Jira AI",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Alice-Jira-AI-${version}-${os}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "conversations.js",
      "package.json",
      "!node_modules",
      "!dist"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "../backend/dist/ai_bridge",
        "to": "backend-dist/ai_bridge"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Alice Jira AI",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Alice Jira AI"
    }
  }
}
