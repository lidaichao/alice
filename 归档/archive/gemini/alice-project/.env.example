# Alice AI Gateway — 环境变量模板
# 复制为 .env 并填入真实值（.env 不会被提交到 Git）
# 也可以直接编辑 global_config.json 替代环境变量

# ── Jira ─────────────────────────────
JIRA_BASE_URL=http://your-jira-server:8080
JIRA_PAT=your-personal-access-token
JIRA_EMAIL=your-email@company.com

# ── AI 模型 ──────────────────────────
DEEPSEEK_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_KEY=sk-your-deepseek-key

# ── 知识库（可选）─────────────────────
NOTION_KEY=ntn_your_notion_integration_token
NOTION_DATABASE_ID=your-database-id
GDRIVE_KEY=your-google-drive-api-key
GDRIVE_FOLDERS=folder-id-1,folder-id-2
GDRIVE_PROXY_IP=
GDRIVE_PROXY_PORT=

# ── SVN + FishEye（可选）──────────────
SVN_URL=https://your-svn-server/svn/project/branches/v3
SVN_USERNAME=your-svn-username
SVN_PASSWORD=your-svn-password
FISHEYE_URL=http://your-fisheye-server:8060

# ── 企业微信（可选）───────────────────
WECOM_CORP_ID=
WECOM_BOT_KEY=

# ── 服务配置 ─────────────────────────
AI_BRIDGE_PORT=9099
LOG_LEVEL=INFO
